<project>
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.github.你的GitHub用户名</groupId>
    <artifactId>arz-common</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-install-plugin</artifactId>
                <version>3.1.1</version>
                <executions>
                    <execution>
                        <id>install-external-jar</id>
                        <!-- 在 validate 阶段先把 jar 注册到本地仓库 -->
                        <phase>validate</phase>
                        <goals>
                            <goal>install-file</goal>
                        </goals>
                        <configuration>
                            <file>${project.basedir}/libs/arz-common-1.0.jar</file>
                            <groupId>com.github.ffewi</groupId>
                            <artifactId>arz-common</artifactId>
                            <version>${project.version}</version>
                            <packaging>jar</packaging>
                            <generatePom>true</generatePom>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>